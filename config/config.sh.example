#!/bin/bash
# =============================================================================
# Liferay Export-Import Validation Tool — Configuration (EXAMPLE)
# =============================================================================
# Copy this file to config.sh and edit values for your environment:
#
#     cp config/config.sh.example config/config.sh
#
# config/config.sh is gitignored. This .example file IS checked into git, so
# don't put credentials or per-developer paths here — keep those in your
# local config.sh.
#
# Every variable below uses the "${NAME:-default}" form so any value can also
# be overridden per-run via an env var:
#
#     SOURCE_GROUP_ID=10182 lfimex --assets blogs
# =============================================================================

# -----------------------------------------------------------------------------
# Portal connection
# -----------------------------------------------------------------------------

BUNDLES_DIR="${BUNDLES_DIR:-/path/to/your/liferay/bundles}"
BASE_URL="${BASE_URL:-http://localhost:8080}"
USERNAME="${USERNAME:-test@liferay.com}"
PASSWORD="${PASSWORD:-test}"

# -----------------------------------------------------------------------------
# Source company & site
# -----------------------------------------------------------------------------

SOURCE_COMPANY_WEB_ID="${SOURCE_COMPANY_WEB_ID:-liferay.com}"
SOURCE_GROUP_ID="${SOURCE_GROUP_ID:-10182}"
SOURCE_PRIVATE_LAYOUT="${SOURCE_PRIVATE_LAYOUT:-false}"

# -----------------------------------------------------------------------------
# Source DB (compare.sh)
# -----------------------------------------------------------------------------

SRC_DB_HOST="${SRC_DB_HOST:-localhost}"
SRC_DB_PORT="${SRC_DB_PORT:-3306}"
SRC_DB_NAME="${SRC_DB_NAME:-lportal}"
SRC_DB_USER="${SRC_DB_USER:-liferay}"
SRC_DB_PASS="${SRC_DB_PASS:-liferay}"

# -----------------------------------------------------------------------------
# Target DB (compare.sh)
# -----------------------------------------------------------------------------

TGT_DB_HOST="${TGT_DB_HOST:-localhost}"
TGT_DB_PORT="${TGT_DB_PORT:-3306}"
TGT_DB_NAME="${TGT_DB_NAME:-lportal}"
TGT_DB_USER="${TGT_DB_USER:-liferay}"
TGT_DB_PASS="${TGT_DB_PASS:-liferay}"

# Unique ID for this run, used in log and result paths. Defaults to a timestamp.
RUN_ID="${RUN_ID:-$(date +%Y%m%d-%H%M%S)}"

# -----------------------------------------------------------------------------
# Paths
# -----------------------------------------------------------------------------

# Project root (parent of config/). Set here once and reused by every entry
# point so they don't all recompute it. The conditional lets a caller supply
# its own value if it's already resolved one.
PROJECT_DIR="${PROJECT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
LIFERAY_LOG_DIR="${LIFERAY_LOG_DIR:-${BUNDLES_DIR}/logs}"
RESULTS_DIR="${RESULTS_DIR:-${PROJECT_DIR}/results}"
RUN_DIR="${RESULTS_DIR}/${RUN_ID}"
COMPARE_SH="${COMPARE_SH:-${PROJECT_DIR}/lib/compare.sh}"

# -----------------------------------------------------------------------------
# General settings
# -----------------------------------------------------------------------------

# INSTANCE_MODE selects the target portal instance for the import:
#   reuse  — use the source company; everything happens in one portal instance.
#   create — call Liferay via "blade sh" + lib/groovy/create-instance.groovy to
#            spin up a fresh Company. Requires the `blade` CLI on PATH and the
#            Gogo Shell reachable from the local machine.
INSTANCE_MODE="${INSTANCE_MODE:-create}"

# BATCH_MODE selects how multiple assets are sent through the pipeline:
#   per-asset (default) — run export → import → validate once per selected
#                         asset. Each asset gets its own LAR and its own
#                         result rows (export:blogs, import:blogs, …).
#   bundled             — run a single export → single import → per-asset
#                         validate. One LAR carries every asset.
BATCH_MODE="${BATCH_MODE:-per-asset}"

# Polling settings for waiting the background import process to complete.
POLL_SECONDS="${POLL_SECONDS:-2}"

# Timeout for the background import process to complete before giving up.
POLL_TIMEOUT="${POLL_TIMEOUT:-8000}"

# Delete the test target instance after the run completes so the bundle stays
# tidy.
#   1 — tear down. In mode=create, drop the new Company (cascades to the
#       site). In mode=reuse, drop only the NEW_SITE_GROUP_ID.
#   0 — keep everything for inspection (default).
CLEANUP_INSTANCE="${CLEANUP_INSTANCE:-0}"

# Copy any files from OSGI_CONFIGS_DIR into the running Liferay's
# osgi/configs/ directory at the start of the run. ConfigAdmin picks them up
# automatically. Off by default; set to 1 (or pass --copy-osgi-configs) to
# enable.
COPY_OSGI_CONFIGS="${COPY_OSGI_CONFIGS:-0}"
OSGI_CONFIGS_DIR="${OSGI_CONFIGS_DIR:-${PROJECT_DIR}/config/osgi}"

# Extended regex (POSIX ERE) matched against ERROR/WARN header lines in the
# Liferay log during bundle-log capture. Matching blocks are dropped before
# counting and summarizing. Combine patterns with `|`.
#
# Default suppressions cover known false positives the pipeline triggers:
#   - "Redirect URL ... is not allowed"
#       Every ExportImportPortlet action sends a redirect= form param so the
#       render-after-action lands on a benign URL; Liferay's portal.url.* allow
#       list often doesn't include it, so RedirectUtil logs a WARN for each
#       POST. Cosmetic.
#   - SerialDestination ClassCastException on liferay/asset_category_asset_entries_reindex
#       Reindex message bus listener occasionally fails to deserialize the
#       payload after a category import; the reindex is retried by Liferay's
#       background task and succeeds. Cosmetic.
#   - "Optional reference generated for missing entity"
#       LAR import logs this whenever a staged model carries an ERC for a
#       referenced entity that doesn't exist on the target (cross-instance
#       imports, pruned dependencies). Liferay degrades the reference to
#       optional and the import continues. Cosmetic.
#   - "The data handler for the \"...\" portlet is missing from the system"
#       StagedGroupStagedModelDataHandler._importSitePortlets logs this when
#       the LAR references a portlet that isn't deployed on the target (e.g.
#       a custom module on source but absent on a fresh target). The import
#       skips that portlet's data and continues. Not actionable from lfimex.
#   - "No theme found for specified theme id ... Returning the default theme"
#       ThemeLocalServiceImpl logs this when a LAR references a theme
#       (e.g. osbcommunity_WAR_osbcommunitytheme) that isn't deployed on
#       the target. Liferay falls back to the default theme; the import
#       continues. Cosmetic when the source uses a theme module the
#       target doesn't have installed.
#   - AntiSamySanitizerImpl
#       AntiSamySanitizerImpl logs one WARN per HTML attribute it strips
#       while sanitizing content (e.g. data-lfr-editable-id, custom data-*
#       attrs in fragment HTML). Imports of fragments and journal articles
#       with rich HTML produce these by the hundreds. The sanitizer
#       silently drops the attribute and keeps the tag, so the content
#       still renders — no functional impact on the migration.
#   - [jericho:NNN]
#       Liferay's HTML parser (Jericho, the open-source library Liferay
#       wraps for content scanning) logs ERROR on every malformed StartTag
#       it encounters in imported HTML — "contains attribute name with
#       invalid character/first character", "rejected because it contains
#       too many errors", "whose content does not match a registered
#       StartTagType". Imports with legacy/hand-edited journal-article
#       HTML produce these by the dozen. Liferay continues parsing; the
#       errors flag malformed source content, not a migration failure.
#   - "Unable to update batch engine export task"
#       BatchEngineExportTaskExecutorImpl logs this ERROR when its
#       manifest-summary prep call to a TaskItemDelegate fails. For
#       lfimex's category export it's a Liferay bug:
#       TaxonomyCategoryResourceImpl.doGetSiteTaxonomyCategoriesPage NPEs
#       on `new long[] {siteId}` because siteId arrives unbound even
#       though the task parameters carry "siteId=NNNN". UI export hits a
#       different code path and doesn't trip it. The manifest-summary
#       count gets dropped but the actual export still runs and the
#       categories migrate correctly — verified via the per-asset
#       category test counts matching across runs.
LIFERAY_LOG_IGNORE_REGEX="${LIFERAY_LOG_IGNORE_REGEX:-(Redirect URL .* is not allowed|destinationName=liferay/asset_category_asset_entries_reindex|Optional reference generated for missing|The data handler for the .* portlet is missing from the system|No theme found for specified theme id .* Returning the default theme|AntiSamySanitizerImpl|[[]jericho:|Unable to update batch engine export task)}"

# -----------------------------------------------------------------------------
# Target company & site
# -----------------------------------------------------------------------------

# Target portal company webId. Used by compare.sh, and — in INSTANCE_MODE=reuse
# — by step_instance to resolve a target company different from the source.
# When this differs from SOURCE_COMPANY_WEB_ID, step_instance looks the target
# company up via Company.webId and points TARGET_BASE_URL at its primary
# virtual host. TARGET_USERNAME / TARGET_PASSWORD must then be set to a valid
# admin in that company. Default: the source company (same-instance import).
TARGET_COMPANY_WEB_ID="${TARGET_COMPANY_WEB_ID:-${SOURCE_COMPANY_WEB_ID}}"

# Pre-existing site groupId to import into. When set, step_site skips the
# headless POST and reuses this group as the import target; step_cleanup
# leaves it alone. The group must belong to the resolved target company
# (validated at startup). Use this for iterative re-imports — combine with
# IMPORT_DATA_STRATEGY=DATA_STRATEGY_MIRROR_OVERWRITE for clean reruns.
# Implies INSTANCE_MODE=reuse (auto-flipped with a warning when set under
# mode=create).
TARGET_GROUP_ID="${TARGET_GROUP_ID:-}"

# Target instance routing overrides. Auto-derived by step_instance when empty:
#   reuse  — defaults to BASE_URL / USERNAME / PASSWORD (and the source
#            company). If TARGET_COMPANY_WEB_ID points elsewhere,
#            TARGET_BASE_URL is built from that company's primary VirtualHost
#            hostname and the port portion of BASE_URL.
#   create — always overwritten with the new company's vhost and admin creds
#            (the user can't predict the auto-generated values).
# Set these explicitly to override routing in reuse mode (e.g. a different
# port, or a pre-deployed admin user that isn't your portal-wide USERNAME).
TARGET_BASE_URL="${TARGET_BASE_URL:-}"
TARGET_USERNAME="${TARGET_USERNAME:-test}"
TARGET_PASSWORD="${TARGET_PASSWORD:-test}"

# Defaults for the new instance created in mode=create.
# Defaults end with .localhost so the virtual host resolves to 127.0.0.1 on
# any modern OS (RFC 6761) without touching /etc/hosts.
NEW_INSTANCE_WEB_ID="${NEW_INSTANCE_WEB_ID:-importtest-${RUN_ID}.localhost}"
NEW_INSTANCE_VIRTUAL_HOST="${NEW_INSTANCE_VIRTUAL_HOST:-importtest-${RUN_ID}.localhost}"
NEW_INSTANCE_MAIL_DOMAIN="${NEW_INSTANCE_MAIL_DOMAIN:-importtest-${RUN_ID}.localhost}"
NEW_INSTANCE_ADMIN_PASSWORD="${NEW_INSTANCE_ADMIN_PASSWORD:-test}"
NEW_INSTANCE_ADMIN_SCREEN_NAME="${NEW_INSTANCE_ADMIN_SCREEN_NAME:-test}"
NEW_INSTANCE_ADMIN_EMAIL="${NEW_INSTANCE_ADMIN_EMAIL:-test@${NEW_INSTANCE_MAIL_DOMAIN}}"
NEW_INSTANCE_ADMIN_FIRST_NAME="${NEW_INSTANCE_ADMIN_FIRST_NAME:-Test}"
NEW_INSTANCE_ADMIN_LAST_NAME="${NEW_INSTANCE_ADMIN_LAST_NAME:-Test}"

NEW_SITE_NAME="${NEW_SITE_NAME:-Imported Site ${RUN_ID}}"

# Import data strategy for both site and globals imports. Liferay's options:
#   DATA_STRATEGY_MIRROR             update entities matched by uuid/ERC,
#                                    leave the rest untouched (default).
#   DATA_STRATEGY_MIRROR_OVERWRITE   like MIRROR but force-overwrite matched
#                                    entities. Best for repeatable re-imports
#                                    into the same TARGET_GROUP_ID.
#   DATA_STRATEGY_COPY_AS_NEW        always insert new rows; never match.
IMPORT_DATA_STRATEGY="${IMPORT_DATA_STRATEGY:-DATA_STRATEGY_MIRROR}"

# -----------------------------------------------------------------------------
# Assets
# -----------------------------------------------------------------------------

# Comma-separated list of asset IDs to include. Use "all" to include every
# registered asset, or "all,-blogs" to subtract from "all". See
# config/asset_catalog.sh for the catalog of supported assets, or run
# `lfimex --list-assets`.
ASSETS="${ASSETS:-all}"

# Comma-separated list of items migrated at the Global level before the
# site cycle, only in INSTANCE_MODE=create. Entries are either:
#   - IDs registered via global_register (e.g. Expando "custom_fields"), or
#   - IDs registered via asset_register (documents_and_media, web_content,
#     fragments, …) — these reuse the asset's portlet + extras but with the
#     source/target Global site as the form's groupId.
# Use "all" for every globals_register entry plus every asset_register entry
# that has a portlet; use "all,-blogs" to subtract from that.
GLOBAL_ASSETS="${GLOBAL_ASSETS:-custom_fields,page_templates,blogs,categories,collections,documents_and_media,forms,fragments,navigation_menus,segments,tags,templates,web_content,wiki}"

# -----------------------------------------------------------------------------
# Tests
# -----------------------------------------------------------------------------

# Comma-separated names of compare.sh tests run once at the end of the
# pipeline (after the per-asset validate phase) as a "site-wide" pass. Each
# entry must correspond to a test file in lib/tests/<name>.sh. Use this for
# tests that aren't tied to a single asset — friendly_url is the canonical
# example, since friendly URLs exist for many entity types at once.
EXTRA_TESTS="${EXTRA_TESTS:-friendly_url}"


# Comma-separated "<test>:<label>" patterns whose checks compare.sh should
# skip. Use "*:<label>" to match the label in any test. Substring match on
# the label. The --ignore-tests CLI flag appends to this list (doesn't
# replace it), so a baseline of well-known false positives lives here and
# one-off run-specific patterns can be added on the command line.
#
# Known false positives to ignore (as of 2024-06):
# ------------------------------------------------
#   blogs:BlogsEntry – Small image and cover image caption (https://liferay.atlassian.net/browse/LPD-85295)
#   blogs:BlogsEntry – Content checksums (https://liferay.atlassian.net/browse/LPD-85295)
#   categories:AssetCategory - Dates (https://liferay.atlassian.net/browse/LPD-86888)
#   documents_and_media:DLFileEntryType – Dates (https://liferay.atlassian.net/browse/LPD-86888)
#   documents_and_media:DLFileEntryMetadata – Identifiers: Liferay regenerates the metadata ERC during import — value differs between
#   documents_and_media:DLFolder – Dates (https://liferay.atlassian.net/browse/LPD-86888)
#   forms:DDMFormInstanceReport – Dates (https://liferay.atlassian.net/browse/LPD-86888)
#   fragments:FragmentComposition – Total count (https://liferay.atlassian.net/browse/LPD-86823)
#   fragments:FragmentComposition – Identifiers (https://liferay.atlassian.net/browse/LPD-86823)
#   fragments:FragmentComposition – Names and descriptions (https://liferay.atlassian.net/browse/LPD-86823)
#   fragments:FragmentComposition – Core fields (https://liferay.atlassian.net/browse/LPD-86823)
#   fragments:FragmentComposition – Data checksum (https://liferay.atlassian.net/browse/LPD-86823)
#   fragments:FragmentComposition – Dates (https://liferay.atlassian.net/browse/LPD-86823)
#   fragments:FragmentEntryLink – Dates (https://liferay.atlassian.net/browse/LPD-85261) 
#   navigation_menus:SiteNavigationMenu – Dates (https://liferay.atlassian.net/browse/LPD-86546)
#   navigation_menus:SiteNavigationMenu – Identifiers https://liferay.atlassian.net/browse/LPD-86546
#   navigation_menus:SiteNavigationMenuItem – Identifiers https://liferay.atlassian.net/browse/LPD-86546
#   navigation_menus:SiteNavigationMenuItem – Dates (https://liferay.atlassian.net/browse/LPD-86546)
#   page_templates:Master Pages – Identifiers (https://liferay.atlassian.net/browse/LPD-86553)
#   page_templates:Master Pages – Dates (https://liferay.atlassian.net/browse/LPD-85261)
#   page_templates:Page Template Collections – Identifiers (https://liferay.atlassian.net/browse/LPD-86553)
#   page_templates:Page Template Collections – Dates (https://liferay.atlassian.net/browse/LPD-85261)
#   page_templates:Page Templates – Identifiers (https://liferay.atlassian.net/browse/LPD-86553)
#   page_templates:Page Templates – Dates (https://liferay.atlassian.net/browse/LPD-85261)
#   page_templates:Display Page Templates – Identifiers (https://liferay.atlassian.net/browse/LPD-86553)
#   page_templates:Display Page Templates – Dates (https://liferay.atlassian.net/browse/LPD-85261)
#   site_pages:Layout – Dates (https://liferay.atlassian.net/browse/LPD-85261)
#   site_pages:LayoutSet – Dates (https://liferay.atlassian.net/browse/LPD-85261)
#   tags:AssetTag – Dates (https://liferay.atlassian.net/browse/LPD-86888)
#   tags:AssetTag – Identifiers https://liferay.atlassian.net/browse/LPD-85252
#   web_content:JournalFolder – Dates (https://liferay.atlassian.net/browse/LPD-86888)
IGNORE_TESTS="${IGNORE_TESTS:-blogs:BlogsEntry – Small image and cover image caption,blogs:BlogsEntry – Content checksums,categories:AssetCategory - Dates,documents_and_media:DLFileEntryType – Dates,documents_and_media:DLFileEntryMetadata – Identifiers,documents_and_media:DLFolder – Dates,forms:DDMFormInstanceReport – Dates,fragments:FragmentComposition – Total count,fragments:FragmentComposition – Identifiers,fragments:FragmentComposition – Names and descriptions,fragments:FragmentComposition – Core fields,fragments:FragmentComposition – Data checksum,fragments:FragmentComposition – Dates,fragments:FragmentEntryLink – Dates,navigation_menus:SiteNavigationMenu – Dates,navigation_menus:SiteNavigationMenu – Identifiers,navigation_menus:SiteNavigationMenuItem – Identifiers,navigation_menus:SiteNavigationMenuItem – Dates,page_templates:Master Pages – Identifiers,page_templates:Master Pages – Dates,page_templates:Page Template Collections – Identifiers,page_templates:Page Template Collections – Dates,page_templates:Page Templates – Identifiers,page_templates:Page Templates – Dates,page_templates:Display Page Templates – Identifiers,page_templates:Display Page Templates – Dates,site_pages:Layout – Dates,site_pages:LayoutSet – Dates,tags:AssetTag – Dates,web_content:JournalFolder – Dates}"

# =============================================================================
# Catalog wiring
# =============================================================================
# The list of supported site assets lives in config/asset_catalog.sh (its own
# file so it can be checked into git while config.sh stays per-developer).
# Selection of which assets actually run happens via ASSETS / GLOBAL_ASSETS
# above (or --assets / --global-assets on the CLI).
# =============================================================================

if ! declare -F asset_register >/dev/null 2>&1; then
  # shellcheck disable=SC1091
  source "${PROJECT_DIR}/lib/assets.sh"
fi
if ! declare -F global_register >/dev/null 2>&1; then
  # shellcheck disable=SC1091
  source "${PROJECT_DIR}/lib/globals.sh"
fi

# shellcheck source=asset_catalog.sh
source "${PROJECT_DIR}/config/asset_catalog.sh"
